<%- include("partials/header") %>

<div class="container-fluid dashboard-wrapper">
  <div class="row">
    <div class="col-md-2 sidebar">
      <h4 class="mb-4">University Portal</h4>
      <ul class="nav flex-column">
        <li class="nav-item mb-2"><a href="/dashboard" class="nav-link">Dashboard</a></li>
        <li class="nav-item mb-2"><a href="/my-courses" class="nav-link">My Courses</a></li>
        <li class="nav-item mb-2"><a href="/profile" class="nav-link active">Profile</a></li>
        <li class="nav-item mb-2"><a href="/logout" class="nav-link">Logout</a></li>
      </ul>
    </div>

    <div class="col-md-10 p-4">
      <div class="top-card mb-4">
        <h3>My Profile</h3>
        <p>View your student details.</p>
      </div>

      <div class="card shadow-sm">
        <div class="card-header bg-white">
          <h5 class="mb-0">Student Information</h5>
        </div>
        <div class="card-body">
          <p><strong>First Name:</strong> <%= user.firstName %></p>
          <p><strong>Middle Name:</strong> <%= user.middleName || "N/A" %></p>
          <p><strong>Last Name:</strong> <%= user.lastName %></p>
          <p><strong>SRN:</strong> <%= user.srn %></p>
          <p><strong>College Email:</strong> <%= user.collegeEmail %></p>
          <p><strong>Personal Email:</strong> <%= user.personalEmail || "N/A" %></p>
          <p><strong>Phone:</strong> <%= user.phone %></p>
          <p><strong>Department:</strong> <%= user.department %></p>
          <p><strong>Semester:</strong> <%= user.semester %></p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include("partials/footer") %>